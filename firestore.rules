rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Data Model (Per-User Isolated)
    // ===============================================================
    //
    // Collection: users/{uid}
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - createdAt: string
    //   - updatedAt: string
    //   - role: string (admin | trainer | client)
    //   - isActive: boolean
    //
    // SubCollection: users/{uid}/students/{studentId}
    // Fields:
    //   - id: string (required)
    //   - shareSlug: string (required)
    //   - name: string (required)
    //   - age: number
    //   - goal: string
    //   - startDate: string
    //   - notes: string
    //   - evaluations: list
    //   - measurements: list
    //   - workouts: list
    //
    // SubCollection: users/{uid}/aulas/{aulaId}
    // Fields:
    //   - id: string (required)
    //   - title: string
    //   - date: string
    //   - time: string
    //   - studentId: string
    //   - notes: string
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "caioweber1@gmail.com");
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['id', 'shareSlug', 'name']) &&
             data.id is string &&
             data.shareSlug is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    // ===============================================================
    // User Profile Collection
    // ===============================================================
    match /users/{uid} {
      // Only the user can read/write their own profile
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow write: if isAuthenticated() && request.auth.uid == uid;
      allow create: if isAuthenticated();

      // ===============================================================
      // Students SubCollection (Per-User Isolated)
      // ===============================================================
      match /students/{studentId} {
        // Only the owner can read their students
        allow read: if isAuthenticated() && request.auth.uid == uid;
        
        // Only the owner can write their students
        allow write: if isAuthenticated() && request.auth.uid == uid;
        
        // Validate student data structure
        allow create: if isAuthenticated() && request.auth.uid == uid && isValidStudent(request.resource.data);
      }

      // ===============================================================
      // Aulas SubCollection (Per-User Isolated)
      // ===============================================================
      match /aulas/{aulaId} {
        // Only the owner can read their sessions
        allow read: if isAuthenticated() && request.auth.uid == uid;
        
        // Only the owner can write their sessions
        allow write: if isAuthenticated() && request.auth.uid == uid;
      }
    }

    // ===============================================================
    // Legacy Collections (Deprecated - for backward compatibility)
    // ===============================================================
    match /students/{studentId} {
      allow read: if true;
      allow write: if false; // Deny all writes to legacy students collection
    }

    match /aulas/{aulaId} {
      allow read: if true;
      allow write: if false; // Deny all writes to legacy aulas collection
    }

    match /sessions/{sessionId} {
      allow read: if true;
      allow write: if false; // Deny all writes to legacy sessions collection
    }
  }
}
