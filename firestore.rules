rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: students
    // Document ID: {studentId}
    // Fields:
    //   - id: string (required)
    //   - shareSlug: string (required)
    //   - name: string (required)
    //   - age: number
    //   - goal: string
    //   - startDate: string
    //   - notes: string
    //   - evaluations: list
    //   - measurements: list
    //   - workouts: list
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "caioweber1@gmail.com");
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['id', 'shareSlug', 'name']) &&
             data.id is string &&
             data.shareSlug is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    // Users collection
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      
      match /{document=**} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // Students collection
    match /students/{studentId} {
      // Allow read for everyone
      allow read: if true;
      
      // Allow write for admin only
      allow write: if isAdmin();
    }

    // Aulas collection
    match /aulas/{aulaId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Sessions collection (legacy)
    match /sessions/{sessionId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
