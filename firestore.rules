rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: students
    // Document ID: {studentId}
    // Fields:
    //   - id: string (required)
    //   - shareSlug: string (required)
    //   - name: string (required)
    //   - age: number
    //   - goal: string
    //   - startDate: string
    //   - notes: string
    //   - evaluations: list
    //   - measurements: list
    //   - workouts: list
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isAuthenticated() && request.auth.uid == ownerId;
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['id', 'adminId', 'shareSlug', 'name']) &&
             data.id is string &&
             data.adminId is string &&
             data.shareSlug is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    function isValidSession(data) {
      return data.keys().hasAll(['id', 'studentId', 'instructorId', 'start', 'end', 'status']) &&
             data.id is string &&
             data.studentId is string &&
             data.instructorId is string &&
             data.start is string &&
             data.end is string &&
             data.status in ['scheduled', 'completed', 'cancelled'] &&
             (!('studentName' in data) || data.studentName is string) &&
             (!('workoutTitle' in data) || data.workoutTitle is string) &&
             (!('notes' in data) || data.notes is string) &&
             (!('googleEventId' in data) || data.googleEventId is string);
    }

    // Users collection
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      
      match /{document=**} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // Students collection
    match /students/{studentId} {
      // Allow read for everyone (for sharing)
      allow read: if true;
      
      // Allow create if authenticated and setting self as admin
      allow create: if isAuthenticated() && 
                    request.resource.data.adminId == request.auth.uid &&
                    isValidStudent(request.resource.data);
      
      // Allow delete if owner
      allow delete: if isOwner(resource.data.adminId);
      
      // Allow update for owner OR for students submitting feedback
      allow update: if isOwner(resource.data.adminId) || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['workouts']) &&
        request.resource.data.id == resource.data.id &&
        request.resource.data.shareSlug == resource.data.shareSlug &&
        request.resource.data.adminId == resource.data.adminId
      );
    }

    // Aulas collection
    match /aulas/{aulaId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
                    request.resource.data.instructorId == request.auth.uid &&
                    isValidSession(request.resource.data);
      allow update: if isOwner(resource.data.instructorId) && 
                    request.resource.data.instructorId == resource.data.instructorId &&
                    isValidSession(request.resource.data);
      allow delete: if isOwner(resource.data.instructorId);
    }

    // Sessions collection (legacy)
    match /sessions/{sessionId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.instructorId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.instructorId);
    }
  }
}
